{
  "name": "sf-parking-heatmap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-meters": "go run ./pipeline fetch-meters",
    "fetch-enforcement": "go run ./pipeline fetch-enforcement",
    "fetch-311": "go run ./pipeline fetch-311",
    "fetch-supply": "go run ./pipeline fetch-supply",
    "compute-paths": "go run ./pipeline compute-paths",
    "aggregate": "go run ./pipeline aggregate",
    "aggregate-bikes": "go run ./pipeline aggregate-bikes",
    "build-speed-profiles": "go run ./pipeline build-speed-profiles",
    "compute-isochrones": "go run ./pipeline compute-isochrones",
    "mock-isochrones": "go run ./pipeline mock-isochrones",
    "pipeline": "go run ./pipeline fetch-meters && go run ./pipeline fetch-enforcement && go run ./pipeline fetch-311 && go run ./pipeline compute-paths && go run ./pipeline aggregate",
    "pipeline-full": "go run ./pipeline fetch-meters && go run ./pipeline fetch-enforcement && go run ./pipeline fetch-311 && go run ./pipeline compute-paths && go run ./pipeline aggregate && go run ./pipeline build-speed-profiles && go run ./pipeline compute-isochrones"
  },
  "dependencies": {
